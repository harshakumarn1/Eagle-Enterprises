<%- layout("boilerplate.ejs") %>

<section class="px-6 md:px-20 py-20 bg-[#f5f7fb]">

  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-10 items-start">

    <!-- LEFT SIDE -->
    <div>

      <h1 class="text-3xl md:text-4xl font-bold text-[#1f2d3d] leading-tight">
        Reliable Facility Services <br> & Material Supply
      </h1>

      <p class="mt-5 text-gray-600 max-w-lg">
        Have a requirement for facility management or material supply?
        Eagle Enterprises delivers dependable and high-quality solutions
        tailored to your business needs.
      </p>

      <!-- INFO CARDS -->
      <div class="mt-10 space-y-5">

        <div class="flex items-start gap-4 bg-white p-5 rounded-xl shadow-sm">
          <div class="bg-blue-500 text-white p-3 rounded-full">📍</div>
          <div>
            <h3 class="font-semibold text-[#1f2d3d]">Our Address</h3>
            <p class="text-gray-600 text-sm">
              EAGLE GLOBAL FACILITY SOLUTIONS PVT LTD <br>
              No: 40, 10th Cross, 2nd Floor, Batavia Heritage, <br>
              Wilson Garden, Bangalore - 560027
            </p>
          </div>
        </div>

        <div class="flex items-start gap-4 bg-white p-5 rounded-xl shadow-sm">
          <div class="bg-blue-500 text-white p-3 rounded-full">📧</div>
          <div>
            <h3 class="font-semibold text-[#1f2d3d]">Our Mailbox</h3>
            <p class="text-gray-600 text-sm">lingam@eaglegroupsindia.com</p>
          </div>
        </div>

        <div class="flex items-start gap-4 bg-white p-5 rounded-xl shadow-sm">
          <div class="bg-blue-500 text-white p-3 rounded-full">📞</div>
          <div>
            <h3 class="font-semibold text-[#1f2d3d]">Our Phone</h3>
            <p class="text-gray-600 text-sm">+91 9538998799</p>
          </div>
        </div>

      </div>

    </div>


    <!-- RIGHT SIDE FORM -->
    <div class="bg-white p-8 rounded-2xl shadow-md border">

      <h2 class="text-xl font-semibold text-[#1f2d3d] mb-4">
        Start Your Project
      </h2>

      <form id="contact-form" class="space-y-4">

        <input type="text" name="name" required placeholder="Your Name *"
          class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">

        <input type="email" name="email" required placeholder="Your Email *"
          class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">

        <input type="text" name="phone" placeholder="Phone Number"
          class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">

        <select name="service"
          class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
          <option>Select Service</option>
          <option>Facility Management</option>
          <option>Material Supply</option>
        </select>

        <textarea name="message" placeholder="Message..." required
          class="w-full border border-gray-300 p-3 rounded-lg h-28 focus:ring-2 focus:ring-blue-500 outline-none"></textarea>

        <button type="submit"
          class="w-full bg-blue-600 text-white py-3 rounded-lg hover:bg-blue-700 transition">
          Send Message
        </button>

      </form>

    </div>

  </div>


</section>

   <section class="px-6 md:px-20 pb-20 bg-[#f5f7fb]">

  <div class="max-w-7xl mx-auto">

    <h2 class="text-2xl md:text-3xl font-semibold text-[#1f2d3d] mb-6">
      Our Location
    </h2>

    <div class="rounded overflow-hidden shadow-lg">

      <iframe 
        class="w-full h-[400px]"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3888.394022571642!2d77.59357327411992!3d12.946620015427383!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bae15446123d041%3A0x5a478c32649d2923!2sEagle%20Global%20Facility%20Solutions%20PVT.%20LTD!5e0!3m2!1sen!2sin!4v1773648797987!5m2!1sen!2sin"
        loading="lazy">
      </iframe>

    </div>

  </div>

</section>